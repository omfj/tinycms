# Required for `cargo sqlx prepare` (compile-time query checking).
# At runtime the app reads the database URL from tinycms.config.ts instead.
DATABASE_URL=postgres://tinycms:tinycms@localhost:5432/tinycms

PORT=3000
RUST_LOG=tinycms=debug,tower_http=debug
# STATIC_DIR=../frontend/dist
# TINYCMS_CONFIG=./tinycms.config.ts

# S3-compatible storage (optional — omit S3_BUCKET to disable uploads)
# The default docker-compose stack starts MinIO on http://localhost:9000.
S3_BUCKET=tinycms-assets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_ENDPOINT_URL=http://localhost:9000/tinycms-assets

# Auth providers (values consumed by tinycms.config.ts via process.env)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
