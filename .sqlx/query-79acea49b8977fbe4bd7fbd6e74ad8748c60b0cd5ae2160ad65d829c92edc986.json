  "query": "UPDATE users SET\n             name   = COALESCE($1, name),\n             status = COALESCE($2::text, status)::text,\n             role   = COALESCE($3::text, role)::text\n           WHERE id = $4\n           RETURNING id, name, email,\n                     status AS \"status: UserStatus\",\n                     role AS \"role: UserRole\",\n                     created_at, updated_at",
