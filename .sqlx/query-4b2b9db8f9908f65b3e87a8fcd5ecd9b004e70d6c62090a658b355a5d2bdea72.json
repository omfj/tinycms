  "query": "SELECT u.id, u.email, u.name,\n                      u.role AS \"role: UserRole\",\n                      u.status AS \"status: UserStatus\"\n               FROM sessions s\n               JOIN users u ON u.id = s.user_id\n               WHERE s.token = $1 AND s.expires_at > now()",
