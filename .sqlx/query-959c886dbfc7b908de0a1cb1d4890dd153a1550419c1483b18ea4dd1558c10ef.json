  "query": "SELECT id, type AS doc_type, status, data AS \"data: Value\",\n                  created_at, updated_at, published_at\n           FROM documents\n           WHERE ($1::text IS NULL OR type = $1)\n             AND ($2::text IS NULL OR status = $2)\n           ORDER BY created_at DESC\n           LIMIT $3 OFFSET $4",
